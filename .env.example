# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ClickUp (direct REST API for autonomous mode) ─────────────────────────────
CLICKUP_API_TOKEN=pk_...

# ── Agent API server ──────────────────────────────────────────────────────────
# Secret token for POST /run endpoint (any string you choose)
API_SECRET_TOKEN=change-me-to-a-long-random-string

# ── Gmail SMTP (for email reports) ────────────────────────────────────────────
# Use a Gmail App Password — NOT your main account password.
# How to get one:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (enable it)
#   2. Go to myaccount.google.com/apppasswords
#   3. Create an app password named "Prometheus iQ"
#   4. Paste the 16-char password below (no spaces)
GMAIL_FROM=gian@yourdomain.com
GMAIL_TO=gian@yourdomain.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── ClickUp Webhook (optional — for signature verification) ───────────────────
# Found in ClickUp: Settings → Integrations → Webhooks → your webhook → secret
CLICKUP_WEBHOOK_SECRET=
