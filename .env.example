# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ClickUp (direct REST API for autonomous mode) ─────────────────────────────
CLICKUP_API_TOKEN=pk_...

# ── Mercury (banking — powers CFO mode with live financial data) ──────────────
# 1. Log in to Mercury → Settings → Developer → API Tokens
# 2. Create a read-only token (accounts + transactions scope)
# Without this, CFO mode falls back to ClickUp data only.
MERCURY_API_TOKEN=

# ── Agent API server ──────────────────────────────────────────────────────────
# Any secret string — used as Bearer token for POST /run
API_SECRET_TOKEN=change-me-to-a-long-random-string

# ── Email reports via Resend (resend.com — free, 3k emails/month) ─────────────
# 1. Sign up at resend.com
# 2. Settings → API Keys → Create API Key
# 3. For the FROM address:
#    - Testing: use "Prometheus iQ <onboarding@resend.dev>" (sends to verified emails only)
#    - Production: verify your own domain at resend.com → Domains
RESEND_API_KEY=re_...
# Production sender (requires domain verification in Resend dashboard for prometheusiq.io):
RESEND_FROM=Gian at Prometheus iQ <communications@prometheusiq.io>
# Prospect outreach reply-to (all outbound emails route replies back to Gian):
RESEND_REPLY_TO=gian@prometheusiq.io
REPORT_TO=gian@prometheusiq.io

# ── ClickUp comment fallback (optional) ───────────────────────────────────────
# If email isn't configured, reports post as comments on this ClickUp task ID.
# Create a "Reports" task in ClickUp and paste its ID here.
REPORT_CLICKUP_TASK=

# ── ClickUp Webhook (optional — for signature verification) ───────────────────
# Found in ClickUp: Settings → Integrations → Webhooks → your webhook → secret
CLICKUP_WEBHOOK_SECRET=

# ── Scheduled morning briefing ────────────────────────────────────────────────
# The server auto-sends the morning briefing via Resend every day at this time.
# Requires RESEND_API_KEY and REPORT_TO to be set.
# BRIEFING_HOUR and BRIEFING_MINUTE use 24-hour format (default: 7:00 AM)
BRIEFING_HOUR=7
BRIEFING_MINUTE=0
BRIEFING_TZ=America/Puerto_Rico
